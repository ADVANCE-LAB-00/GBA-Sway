configuration {
modi: "drun,run,window";
show-icons: false;
display-drun: "Apps";
display-run: "Run";
sidebar-mode: false;

  timeout {
      action: "kb-cancel";
      delay:  0;
  }
  filebrowser {
      directories-first: true;
      sorting-method:    "name";
  }

}

@theme "/usr/share/rofi/themes/gba"
